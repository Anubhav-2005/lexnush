# Local development only. Never commit a populated .env file.
LEXNUSH_ENV=development
SECRET_KEY=generate-a-long-random-local-secret
PUBLIC_BASE_URL=http://localhost:8000
LEXNUSH_TRUSTED_HOSTS=localhost,127.0.0.1
TRUSTED_PROXY_COUNT=0
PORT=8000

# Local defaults use SQLite and in-memory limits. Production requires managed services.
# DATABASE_URL=sqlite:///instance/lexnush.sqlite3
REDIS_URL=memory://
DATA_RETENTION_DAYS=365

# Resend email (required for production startup)
RESEND_API_KEY=
MAIL_FROM=LexNush <hello@example.com>
CONTACT_RECIPIENT_EMAIL=
EMAIL_DELIVERY_ENABLED=false

# Protected single-operator dashboard (required for production startup)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Optional observability and bot protection
SENTRY_DSN=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRED=false
